# =========================================================
# 伊甸健康小幫手 LINE Bot — 環境變數設定範本
# 複製此檔案為 .env，並填入您的實際金鑰
# =========================================================

# ── LINE Messaging API ────────────────────────────────────
# 至 LINE Developers Console > 您的 Channel > Basic settings 取得
LINE_CHANNEL_SECRET=YOUR_LINE_CHANNEL_SECRET

# 至 LINE Developers Console > 您的 Channel > Messaging API > Channel access token 取得
LINE_CHANNEL_ACCESS_TOKEN=YOUR_LINE_CHANNEL_ACCESS_TOKEN

# ── ngrok 公開 URL ────────────────────────────────────────
# 啟動 ngrok 後取得，例如 https://xxxx-xx-xx.ngrok-free.app
# 同時需設定為 LINE Webhook URL（後面加上 /callback）
NGROK_URL=YOUR_NGROK_URL

# ── Google Drive ──────────────────────────────────────────
# 存放知識庫文件的 Google Drive 資料夾 ID
# 從資料夾分享連結中取得，例如：
#   https://drive.google.com/drive/folders/<FOLDER_ID>
GOOGLE_DRIVE_FOLDER_ID=YOUR_GOOGLE_DRIVE_FOLDER_ID

# ── Google Sheets ─────────────────────────────────────────
# 用於記錄使用者評分與查無資料問題的 Google Spreadsheet ID
# 從試算表網址中取得，例如：
#   https://docs.google.com/spreadsheets/d/<SPREADSHEET_ID>/edit
GOOGLE_SPREADSHEET_ID=YOUR_GOOGLE_SPREADSHEET_ID

# ── Google 服務帳號金鑰 ───────────────────────────────────
# 服務帳號 JSON 金鑰檔案路徑（預設為專案根目錄下的 service_account.json）
# 請至 Google Cloud Console > IAM 與管理 > 服務帳號 建立並下載
# 注意：此檔案已列入 .gitignore，請勿上傳至版本控制
SERVICE_ACCOUNT_FILE=service_account.json
